<UserControl x:Class="EasySave.GUI.Views.JobExecutionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:EasySave.GUI.ViewModels">
    <UserControl.DataContext>
        <viewModels:JobExecutionViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,12">
            <Button Content="Start monitoring"
                    Width="140"
                    Margin="0,0,8,0"
                    Command="{Binding StartMonitoringCommand}" />

            <Button Content="Stop monitoring"
                    Width="140"
                    Command="{Binding StopMonitoringCommand}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Margin="0,0,0,12">
            <TextBlock Text="{Binding MonitoringStatus}"
                       Margin="0,0,0,6" />

            <ProgressBar Minimum="0"
                         Maximum="100"
                         Height="22"
                         Value="{Binding GlobalProgression}" />

            <TextBlock Text="{Binding GlobalProgression, StringFormat=Global progression: {0}%}"
                       Margin="0,6,0,0" />
        </StackPanel>

    <GroupBox Grid.Row="2"
          Header="Job states"
          Padding="12">
                <DataGrid ItemsSource="{Binding JobStates}"
              AutoGenerateColumns="False"
              IsReadOnly="True">
                <DataGrid.Columns>
                            <DataGridTextColumn Header="Backup"
                                Binding="{Binding BackupName}"
                                Width="*" />
                                <DataGridTextColumn Header="Status"
                                Binding="{Binding Status}"
                                Width="120" />
                <DataGridTextColumn Header="Progress"
                                Binding="{Binding Progression}"
                                Width="100" />
            <DataGridTextColumn Header="Remaining files"
                                Binding="{Binding RemainingFiles}"
                                Width="120" />
            <DataGridTextColumn Header="Remaining size"
                                Binding="{Binding RemainingSize}"
                                Width="120" />
            <DataGridTextColumn Header="Current source"
                                Binding="{Binding CurrentSourceFile}"
                                Width="2*" />
            <DataGridTextColumn Header="Current target"
                                Binding="{Binding CurrentTargetFile}"
                                Width="2*" />
        </DataGrid.Columns>
    </DataGrid>
    </GroupBox>

        <TextBlock Grid.Row="3"
                   Margin="0,12,0,0"
                   Text="This screen will later read real-time data from StateTracker." />
    </Grid>
</UserControl>