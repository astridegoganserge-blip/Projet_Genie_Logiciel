<UserControl x:Class="EasySave.GUI.Views.JobExecutionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:EasySave.GUI.ViewModels">
    <UserControl.DataContext>
        <viewModels:JobExecutionViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,12">
            <Button Content="Start monitoring"
                    Width="140"
                    Margin="0,0,8,0"
                    Command="{Binding StartMonitoringCommand}" />

            <Button Content="Stop monitoring"
                    Width="140"
                    Command="{Binding StopMonitoringCommand}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Margin="0,0,0,12">
            <TextBlock Text="{Binding MonitoringStatus}"
                       Margin="0,0,0,6" />

            <ProgressBar Minimum="0"
                         Maximum="100"
                         Height="22"
                         Value="{Binding GlobalProgression}" />

            <TextBlock Text="{Binding GlobalProgression, StringFormat=Global progression: {0}%}"
                       Margin="0,6,0,0" />
        </StackPanel>

        <GroupBox Grid.Row="2"
                  Header="Job states"
                  Padding="12">
            <ListBox ItemsSource="{Binding JobStates}" />
        </GroupBox>

        <TextBlock Grid.Row="3"
                   Margin="0,12,0,0"
                   Text="This screen will later read real-time data from StateTracker." />
    </Grid>
</UserControl>