<UserControl x:Class="EasySave.GUI.Views.JobListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:EasySave.GUI.ViewModels">
    <UserControl.DataContext>
        <viewModels:JobListViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">
            <TextBlock Text="▣"
                       FontSize="24"
                       Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0" />

            <TextBlock Text="{DynamicResource NavBackupJobs}"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- ACTION BAR -->
        <Grid Grid.Row="1"
              Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="{DynamicResource BtnExecute}"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Margin="0,0,10,0"
                    Command="{Binding ExecuteJobCommand}"
                    CommandParameter="{Binding SelectedItem, ElementName=JobsDataGrid}" />

            <Button Grid.Column="1"
                    Content="{DynamicResource BtnExecuteAll}"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Margin="0,0,10,0"
                    Command="{Binding ExecuteAllCommand}" />

            <Button Grid.Column="2"
                    Content="{DynamicResource BtnRefresh}"
                    Style="{StaticResource SecondaryActionButtonStyle}"
                    Margin="0,0,10,0"
                    Command="{Binding RefreshCommand}" />

            <Button Grid.Column="3"
                    Content="{DynamicResource BtnDelete}"
                    Style="{StaticResource DangerButtonStyle}"
                    Margin="0,0,10,0"
                    Command="{Binding DeleteJobCommand}" />

            <Button Grid.Column="5"
                    Content="{DynamicResource NavCreateJob}"
                    Style="{StaticResource PrimaryActionButtonStyle}"
                    Command="{Binding CreateJobCommand}" />
        </Grid>

        <!-- TABLE -->
        <DataGrid x:Name="JobsDataGrid"
                  Grid.Row="2"
                  ItemsSource="{Binding Jobs}"
                  SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="N°"
                                    Binding="{Binding Number, StringFormat={}{0:00}}"
                                    Width="60" />

                <DataGridTextColumn Header="{StaticResource HeaderName}"
                                    Binding="{Binding Name}"
                                    Width="160" />

                <DataGridTextColumn Header="{StaticResource HeaderSource}"
                                    Binding="{Binding SourcePath}"
                                    Width="250" />

                <DataGridTextColumn Header="{StaticResource HeaderTarget}"
                                    Binding="{Binding TargetPath}"
                                    Width="250" />

                <DataGridTextColumn Header="{StaticResource HeaderType}"
                                    Binding="{Binding Type}"
                                    Width="120" />

                <DataGridTextColumn Header="{StaticResource HeaderLastExecution}"
                                    Binding="{Binding LastExecutionTime}"
                                    Width="180" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- STATUS -->
        <Border Grid.Row="3"
                BorderBrush="{StaticResource BorderLightBrush}"
                BorderThickness="0,1,0,0"
                Margin="0,18,0,0"
                Padding="0,14,0,0">
            <StackPanel Orientation="Horizontal">
                <Border Width="26"
                        Height="26"
                        CornerRadius="13"
                        Background="{StaticResource AccentBrush}"
                        Margin="0,0,10,0">
                    <TextBlock Text="i"
                               Foreground="White"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>