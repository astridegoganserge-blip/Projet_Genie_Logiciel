<UserControl x:Class="EasySave.GUI.Views.JobListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:EasySave.GUI.ViewModels">
    <UserControl.DataContext>
        <viewModels:JobListViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,12">
            <Button Content="{DynamicResource BtnCreate}"
                    Width="100"
                    Margin="0,0,8,0"
                    Command="{Binding CreateJobCommand}" />

            <Button Content="{DynamicResource BtnExecute}"
                    Width="100"
                    Margin="0,0,8,0"
                    Command="{Binding ExecuteJobCommand}"
                    CommandParameter="{Binding SelectedItem, ElementName=JobsDataGrid}" />

            <Button Content="{DynamicResource BtnDelete}"
                    Width="100"
                    Margin="0,0,8,0"
                    Command="{Binding DeleteJobCommand}" />

            <Button Content="{DynamicResource BtnRefresh}"
                    Width="100"
                    Command="{Binding RefreshCommand}" />
        </StackPanel>

        <DataGrid x:Name="JobsDataGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding Jobs}"
                  SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
<DataGridTextColumn Header="{DynamicResource HeaderId}" Binding="{Binding Id}" Width="220" />
<DataGridTextColumn Header="{DynamicResource HeaderName}" Binding="{Binding Name}" Width="*" />
<DataGridTextColumn Header="{DynamicResource HeaderSource}" Binding="{Binding SourcePath}" Width="2*" />
<DataGridTextColumn Header="{DynamicResource HeaderTarget}" Binding="{Binding TargetPath}" Width="2*" />
<DataGridTextColumn Header="{DynamicResource HeaderType}" Binding="{Binding Type}" Width="120" />
<DataGridTextColumn Header="{DynamicResource HeaderLastExecution}" Binding="{Binding LastExecutionTime}" Width="160" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>