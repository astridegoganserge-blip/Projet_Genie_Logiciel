<UserControl x:Class="EasySave.GUI.Views.JobListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:EasySave.GUI.ViewModels">
    <UserControl.DataContext>
        <viewModels:JobListViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,12">
            <Button Content="Create"
                    Width="100"
                    Margin="0,0,8,0"
                    Command="{Binding CreateJobCommand}" />

            <Button Content="Execute"
                    Width="100"
                    Margin="0,0,8,0"
                    Command="{Binding ExecuteJobCommand}" />

            <Button Content="Delete"
                    Width="100"
                    Margin="0,0,8,0"
                    Command="{Binding DeleteJobCommand}" />

            <Button Content="Refresh"
                    Width="100"
                    Command="{Binding RefreshCommand}" />
        </StackPanel>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Jobs}"
                 SelectedItem="{Binding SelectedJob, Mode=TwoWay}" />

        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>