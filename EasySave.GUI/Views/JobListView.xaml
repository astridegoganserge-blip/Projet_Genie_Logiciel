<UserControl x:Class="EasySave.GUI.Views.JobListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:EasySave.GUI.ViewModels">
    <UserControl.DataContext>
        <viewModels:JobListViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,12">
            <Button Content="Create"
                    Width="100"
                    Margin="0,0,8,0"
                    Command="{Binding CreateJobCommand}" />

            <Button Content="Execute"
                    Width="100"
                    Margin="0,0,8,0"
                    Command="{Binding ExecuteJobCommand}" />

            <Button Content="Delete"
                    Width="100"
                    Margin="0,0,8,0"
                    Command="{Binding DeleteJobCommand}" />

            <Button Content="Refresh"
                    Width="100"
                    Command="{Binding RefreshCommand}" />
        </StackPanel>

        <DataGrid Grid.Row="1"
                ItemsSource="{Binding Jobs}"
                SelectedItem="{Binding SelectedJob, Mode=TwoWay}"
                AutoGenerateColumns="False"
                IsReadOnly="True">
        <DataGrid.Columns>
                
                <DataGridTextColumn Header="Id"
                                Binding="{Binding Id}"
                                Width="220" />
                <DataGridTextColumn Header="Name"
                                Binding="{Binding Name}"
                                Width="*" />
                <DataGridTextColumn Header="Source"
                                Binding="{Binding SourcePath}"
                                Width="2*" />
                <DataGridTextColumn Header="Target"
                                Binding="{Binding TargetPath}"
                                Width="2*" />
                <DataGridTextColumn Header="Type"
                                Binding="{Binding Type}"
                                Width="120" />
                <DataGridTextColumn Header="Last execution"
                                Binding="{Binding LastExecutionTime}"
                                Width="160" />
        </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>