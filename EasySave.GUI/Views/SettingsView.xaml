<UserControl x:Class="EasySave.GUI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:EasySave.GUI.ViewModels">
    <UserControl.DataContext>
        <viewModels:SettingsViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Header="Language"
          Padding="12"
          Margin="0,0,0,12">
    <StackPanel>
        <TextBlock Text="Application language:" />
        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                  Width="180"
                  HorizontalAlignment="Left"
                  Margin="0,6,0,0" />
    </StackPanel>
</GroupBox>

        <GroupBox Header="Language"
                    Padding="12"
                    Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Application language:" />
                <ComboBox ItemsSource="{Binding AvailableLanguages}"
                  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                  Width="180"
                  HorizontalAlignment="Left"
                  Margin="0,6,0,0" />
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="1"
                Header="Log format"
                Padding="12"
                 Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Daily log format:" />
                <ComboBox ItemsSource="{Binding AvailableFormats}"
                          SelectedItem="{Binding SelectedLogFormat, Mode=TwoWay}"
                          Width="180"
                          HorizontalAlignment="Left"
                          Margin="0,6,0,0" />
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2"
                  Header="Business software"
                  Padding="12"
                  Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Process name to monitor:" />
                <TextBox Text="{Binding BusinessSoftware, UpdateSourceTrigger=PropertyChanged}"
                         Width="250"
                         HorizontalAlignment="Left"
                         Margin="0,6,0,0" />
                <TextBlock Text="Example: calc"
                           FontStyle="Italic"
                           Margin="0,4,0,0" />
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="3"
                  Header="Extensions to encrypt"
                  Padding="12"
                  Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding NewExtensionInput, UpdateSourceTrigger=PropertyChanged}"
                             Width="160"
                             Margin="0,0,8,0" />

                    <Button Content="Add"
                            Width="80"
                            Command="{Binding AddExtensionCommand}" />
                </StackPanel>

                <ListBox Grid.Row="1"
                         Margin="0,10,0,0"
                         ItemsSource="{Binding ExtensionsToEncrypt}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Button Content="Remove"
                                        DockPanel.Dock="Right"
                                        Margin="8,0,0,0"
                                        Command="{Binding DataContext.RemoveExtensionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}" />
                                <TextBlock Text="{Binding}" />
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal">
            <Button Content="Save settings"
                    Width="130"
                    Command="{Binding SaveCommand}" />

            <TextBlock Text="{Binding SuccessMessage}"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>