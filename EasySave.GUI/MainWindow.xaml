<Window x:Class="EasySave.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppTitle}"
        Height="650"
        Width="1150"
        MinHeight="580"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0"
                Background="{StaticResource PrimaryBrush}">
            <DockPanel Margin="18">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="{DynamicResource AppTitle}"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,18,0,4" />

                    <TextBlock Text="ProSoft Backup Manager"
                               Foreground="#C7D2FE"
                               FontSize="13"
                               Margin="0,0,0,38" />

                    <Button Content="{DynamicResource NavBackupJobs}"
                            Style="{StaticResource SelectedNavButtonStyle}"
                            Command="{Binding ShowJobsCommand}" />

                    <Button Content="{DynamicResource NavCreateJob}"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowCreateJobCommand}" />

                    <Button Content="{DynamicResource NavSettings}"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowSettingsCommand}" />

                    <Button Content="{DynamicResource NavExecution}"
                            Style="{StaticResource NavButtonStyle}"
                            Command="{Binding ShowExecutionCommand}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Border Height="1"
                            Background="#35577C"
                            Margin="0,0,0,18" />

                    <TextBlock Text="EasySave v2.0 - MVVM"
                               Foreground="#C7D2FE"
                               FontSize="12" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN AREA -->
        <Grid Grid.Column="1"
              Margin="26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- TOP HEADER CARD -->
            <Border Grid.Row="0"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="{DynamicResource AppTitle}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock Text="Console V1.1 compatible - WPF MVVM V2.0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="14"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <!-- CONTENT CARD -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardBorderStyle}">
                <ContentControl Content="{Binding CurrentView}" />
            </Border>
        </Grid>
    </Grid>
</Window>