<Window x:Class="EasySave.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding ApplicationTitle}"
        Height="500"
        Width="900"
        MinHeight="450"
        MinWidth="800">
    <DockPanel>
        <Border DockPanel.Dock="Top"
                Padding="12"
                BorderThickness="0,0,0,1"
                BorderBrush="#DDDDDD">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding ApplicationTitle}"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,30,0" />

                <Button Content="Backup jobs"
                        Width="120"
                        Margin="0,0,8,0"
                        Command="{Binding ShowJobsCommand}" />

                <Button Content="Settings"
                        Width="120"
                        Margin="0,0,8,0"
                        Command="{Binding ShowSettingsCommand}" />

                <Button Content="Execution"
                        Width="120"
                        Command="{Binding ShowExecutionCommand}" />
            </StackPanel>
        </Border>

        <Border Padding="20">
            <ContentControl Content="{Binding CurrentView}" />
        </Border>
    </DockPanel>
</Window>